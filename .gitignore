# =========================
# Data artifacts (keep manifests, ignore big/binary by default)
# =========================
# If you decide to commit a tiny demo Parquet, you can override with a negation rule.
*.parquet
*.arrow
*.feather
*.h5
*.hdf5
*.npz
*.npy
*.pkl
*.pickle

# Common compressed data
*.csv.gz
*.jsonl.gz
*.parquet.gz
*.tar
*.tar.gz
*.tgz
*.zip
*.7z
*.xz

# Allow specific tiny demo artifacts if you choose to keep them in-repo:
!datasets/synthetic/job-failure/tiny/data.parquet
!tests/fixtures/expected_job_table.parquet
!src/hpc_oda_commons/datasets/synthetic/job-runtime/tiny/data.parquet

