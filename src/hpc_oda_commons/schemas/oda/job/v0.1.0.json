{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hpc-oda-commons.org/schemas/oda/job/v0.1.0.json",
  "title": "ODA Job Schema v0.1.0 (Runtime Prediction)",
  "type": "object",
  "additionalProperties": true,
  "required": ["job_id", "start_time", "end_time", "runtime_seconds"],
  "properties": {
    "job_id": {
      "description": "SLURM Job ID",
      "type": ["integer", "string"]
    },
    "start_time": {
      "description": "Job start time (UTC ISO-8601)",
      "type": "string",
      "format": "date-time"
    },
    "end_time": {
      "description": "Job end time (UTC ISO-8601)",
      "type": "string",
      "format": "date-time"
    },
    "runtime_seconds": {
      "description": "Canonical runtime target: end_time - start_time (seconds)",
      "type": ["number", "null"],
      "minimum": 0
    },
    "allocated_cpus": {
      "type": ["integer", "null"],
      "minimum": 1
    },
    "partition": {
      "type": ["string", "null"]
    },
    "node_list": {
      "type": ["string", "null"]
    }
  }
}
